{
  "projectName": "Text block reveal",
  "description": "Project to reveal a text with a block with gsap animation",
  "date": "2026-03-26",
  "inspirationLink": "",
  "inspirationText": "",
  "technologies": "GSAP / React.js",
  "isInteractive": false,
  "controls": [
    {
      "type": "textarea",
      "key": "text",
      "label": "Text",
      "default": "Reveal your power\nunleash your potential\nwith every word you speak",
      "rows": 4
    },
    {
      "type": "slider",
      "key": "fontSize",
      "label": "Font Size",
      "default": 48,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "type": "slider",
      "key": "maxWidth",
      "label": "Container Max Width",
      "default": 600,
      "min": 200,
      "max": 1200,
      "step": 50
    },
    {
      "type": "slider",
      "key": "lineHeight",
      "label": "Line Height",
      "default": 1.2,
      "min": 0.8,
      "max": 2,
      "step": 0.1
    },
    {
      "type": "color",
      "key": "color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "key": "blockColor",
      "label": "Block Color",
      "default": "#ff0000"
    },
    {
      "type": "slider",
      "key": "animationSpeed",
      "label": "Animation Speed",
      "default": 0.8,
      "min": 0.1,
      "max": 3,
      "step": 0.1
    },
    {
      "type": "slider",
      "key": "staggerDelay",
      "label": "Stagger Delay",
      "default": 0.15,
      "min": 0,
      "max": 1,
      "step": 0.05
    },
    {
      "type": "select",
      "key": "direction",
      "label": "Direction",
      "default": "bottom-to-top",
      "options": [
        {
          "value": "bottom-to-top",
          "label": "Bottom to Top"
        },
        {
          "value": "top-to-bottom",
          "label": "Top to Bottom"
        },
        {
          "value": "left-to-right",
          "label": "Left to Right"
        },
        {
          "value": "right-to-left",
          "label": "Right to Left"
        }
      ]
    },
    {
      "type": "button",
      "label": "Reset Animation",
      "actionId": "replay"
    }
  ]
}

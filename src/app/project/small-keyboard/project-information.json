{
  "slug": "small-keyboard",
  "projectName": "Small keyboard",
  "description": "Small keyboard with simple key press functions",
  "date": "2025-01-17",
  "technologies": "Three.js / React.js",
  "isInteractive": true,
  "controls": [
    {
      "type": "color",
      "key": "keyColor",
      "label": "Key Color",
      "default": "#f0ede6"
    },
    {
      "type": "color",
      "key": "accentColor",
      "label": "Accent Key",
      "default": "#e07c24"
    },
    {
      "type": "slider",
      "key": "lightIntensity",
      "label": "Light Intensity",
      "default": 2,
      "min": 0,
      "max": 10,
      "step": 0.1
    }
  ]
}

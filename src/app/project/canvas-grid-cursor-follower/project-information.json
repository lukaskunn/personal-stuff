{
  "projectName": "Canvas Grid — Cursor Follow",
  "description": "A canvas grid over a background image. Cells near the cursor are painted black within a configurable radius.",
  "date": "2026-04-09",
  "technologies": "React.js / Canvas",
  "isInteractive": true,
  "controls": [
    {
      "type": "slider",
      "key": "cellSize",
      "label": "Cell Size (px)",
      "default": 40,
      "min": 8,
      "max": 80,
      "step": 1
    },
    {
      "type": "slider",
      "key": "brushRadius",
      "label": "Brush Radius (cells)",
      "default": 3,
      "min": 1,
      "max": 12,
      "step": 1
    },
    {
      "type": "slider",
      "key": "tailLife",
      "label": "Tail Life (ms)",
      "default": 240,
      "min": 40,
      "max": 800,
      "step": 20
    },
    {
      "type": "slider",
      "key": "charLife",
      "label": "Char Life (ms)",
      "default": 1000,
      "min": 100,
      "max": 5000,
      "step": 100
    },
    {
      "type": "slider",
      "key": "bigBlockChance",
      "label": "Big Block Chance",
      "default": 0.18,
      "min": 0,
      "max": 0.5,
      "step": 0.01
    }
  ]
}

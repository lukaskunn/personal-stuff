{
  "projectName": "Ascii filter",
  "description": "Simple project to apply ascii filter to three js scene",
  "date": "2025-01-31",
  "technologies": "Three.js / React.js",
  "isInteractive": true,
  "controls": [
    {
      "type": "text",
      "key": "density",
      "label": "Density String",
      "default": "Ñ@#WMB%$&O08GCLft1i;:,. "
    },
    {
      "type": "slider",
      "key": "fontSize",
      "label": "Font Size",
      "default": 54,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "type": "slider",
      "key": "cellSize",
      "label": "Cell Size",
      "default": 9,
      "min": 1,
      "max": 100,
      "step": 1
    },
    {
      "type": "color",
      "key": "color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "toggle",
      "key": "invert",
      "label": "Invert",
      "default": true
    }
  ]
}

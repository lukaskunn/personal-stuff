{
  "projectName": "Cursor Follower Pictures",
  "description": "A custom cursor follower component that creates an animated trail of pictures with a short lifespan. Move your cursor around to see pictures appear and fade away.",
  "date": "2026-04-15",
  "inspirationLink": "",
  "inspirationText": "",
  "technologies": "React.js / Canvas / requestAnimationFrame",
  "isInteractive": true,
  "controls": [
    {
      "type": "slider",
      "key": "pictureSize",
      "label": "Picture Size",
      "default": 240,
      "min": 40,
      "max": 300,
      "step": 1
    },
    {
      "type": "slider",
      "key": "spawnDistance",
      "label": "Spawn Distance (px)",
      "default": 140,
      "min": 20,
      "max": 200,
      "step": 5
    },
    {
      "type": "slider",
      "key": "lifespan",
      "label": "Lifespan (ms)",
      "default": 500,
      "min": 100,
      "max": 3000,
      "step": 100
    },
    {
      "type": "slider",
      "key": "opacity",
      "label": "Opacity",
      "default": 1,
      "min": 0.1,
      "max": 1,
      "step": 0.05
    }
  ]
}
